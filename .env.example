# Mullvad WireGuard private key
# Get it from: mullvad.net → Account → WireGuard configuration → Generate key
# Or run: bash scripts/rotate_key.sh to generate and register automatically
MULLVAD_WG_KEY=your_wireguard_private_key_here

# Assigned IP returned by Mullvad when you register the key (e.g. 10.68.x.x/32)
MULLVAD_WG_ADDR=10.x.x.x/32

# Mullvad account number (used by rotate_key.sh only, not by gluetun)
MULLVAD_ACCOUNT=0000000000000000

# VPN exit country (optional, defaults to Netherlands)
VPN_COUNTRY=Netherlands
